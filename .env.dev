COMPOSE_PROJECT_NAME=kflow-dev
IMAGE_TAG=dev

DOMAIN=localhost
PUBLIC_URL=https://localhost
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
TLS_CERT_FILE=./.local/certs/localhost.crt
TLS_KEY_FILE=./.local/certs/localhost.key

POSTGRES_USER=appuser
POSTGRES_PASSWORD=dev-postgres-password
POSTGRES_DB=aidb
POSTGRES_SHARED_BUFFERS_MB=256
POSTGRES_WORK_MEM_MB=8
POSTGRES_MAINT_WORK_MEM_MB=64
POSTGRES_EFFECTIVE_CACHE_MB=512

DIRECTUS_KEY=dev-directus-key-please-change-before-prod
DIRECTUS_SECRET=dev-directus-secret-please-change-before-prod
DIRECTUS_ADMIN_EMAIL=admin@knowledge-flows.com
DIRECTUS_ADMIN_PASS=dev-directus-admin-password

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=dev-keycloak-admin-password
JENA_ADMIN_PASSWORD=dev-jena-admin-password

POSTGRES_MEMORY_LIMIT=700m
REDIS_MEMORY_LIMIT=128m
DIRECTUS_MEMORY_LIMIT=700m
JENA_MEMORY_LIMIT=700m
QDRANT_MEMORY_LIMIT=700m
FASTAPI_MEMORY_LIMIT=256m
RAG_MEMORY_LIMIT=512m
QR_MEMORY_LIMIT=128m
NGINX_MEMORY_LIMIT=128m
PROMETHEUS_MEMORY_LIMIT=256m
GRAFANA_MEMORY_LIMIT=384m
KEYCLOAK_MEMORY_LIMIT=900m
OLLAMA_MEMORY_LIMIT=1800m

PROMETHEUS_RETENTION=7d
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=dev-grafana-admin-password

RAG_COLLECTION=kflow_documents
RAG_VECTOR_SIZE=384
OLLAMA_URL=
OLLAMA_MODEL=phi3:mini
